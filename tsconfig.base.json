{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/web/src/*"],
      "@astro-sim/astronomy-data": ["packages/astronomy-data/src"],
      "@astro-sim/orbital-mechanics": ["packages/orbital-mechanics/src"],
      "@astro-sim/physics-engine": ["packages/physics-engine/src"],
      "@astro-sim/shared-utils": ["packages/shared-utils/src"],
      "@astro-sim/simulation-ui": ["packages/simulation-ui/src"],
      "@astro-sim/visualization-engine": ["packages/visualization-engine/src"],
      "@astro-sim/solar-system-orbits": ["simulations/01-solar-system-orbits/src"]
    }
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "simulations/**/*.ts",
    "simulations/**/*.tsx",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", ".next", "dist", "coverage"]
}

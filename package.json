{
  "name": "astronomy-and-astrophysics-simulations",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source computational astronomy and astrophysics simulations by Prabhmannat Singh.",
  "author": "Prabhmannat Singh",
  "license": "Apache-2.0",
  "copyright": "Copyright 2026 Prabhmannat Singh",
  "packageManager": "npm@11.0.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "simulations/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @astro-sim/web",
    "build": "npm run build -w @astro-sim/web",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint simulations",
    "format": "prettier --check simulations"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.185.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.64.0",
    "vitest": "^2.1.8"
  }
}
